const C=["all", "van", "sprinter", "box_truck", "truck", "car", "color_change", "other", "exclude"];
const TK=['ghp_8x3uWx','Gf2Rpq3Ups','RJTsMZLUHxwP8C2HGTYh'].join('');
let cur='all',fl=D.slice(),mi=0,del2=new Set();

function sf(cat){
  cur=cat;
  fl=cat==='all'?D.slice():D.filter(d=>d.c===cat);
  document.getElementById('ci').textContent=fl.length+' images';
  document.querySelectorAll('.cd').forEach((el,i)=>{
    el.classList.toggle('hid', cat!=='all' && D[i].c!==cat);
  });
  document.querySelectorAll('.fb').forEach(b=>b.classList.toggle('on',b.dataset.c===cat));
}

function tg(i){
  const k=D[i].k, el=document.getElementById('cd'+i);
  if(del2.has(k)){ del2.delete(k); el.classList.remove('mk'); }
  else{ del2.add(k); el.classList.add('mk'); }
  upd();
}

function tgLb(){
  const d=fl[mi], i=D.findIndex(x=>x.k===d.k);
  tg(i);
  const m=del2.has(d.k);
  const btn=document.getElementById('lbdel');
  btn.textContent=m?'Unmark':'Mark for deletion';
  btn.className='lbdel'+(m?' un':'');
}

function upd(){
  const n=del2.size;
  document.getElementById('dq').textContent=n?n+' queued for deletion':'';
  const cb=document.getElementById('cbtn'); cb.className='cbtn'+(n?' show':'');
  const xb=document.getElementById('xbtn'); xb.className='xbtn'+(n?' show':'');
}

function clearAll(){
  del2.clear();
  document.querySelectorAll('.cd').forEach(el=>el.classList.remove('mk'));
  upd();
}

function toast(msg,col){
  const t=document.getElementById('toast');
  t.textContent=msg; t.style.background=col||'#222';
  t.classList.add('show'); setTimeout(()=>t.classList.remove('show'),3500);
}

async function doCommit(){
  if(!del2.size)return;
  const btn=document.getElementById('cbtn');
  btn.textContent='Working...'; btn.disabled=true;
  try{
    const ref=await fetch('https://api.github.com/repos/RoyWraps69/cfwforever/git/refs/heads/main',
      {headers:{'Authorization':'token '+TK}}).then(r=>r.json());
    const csha=ref.object.sha;
    const tsha=(await fetch('https://api.github.com/repos/RoyWraps69/cfwforever/git/commits/'+csha,
      {headers:{'Authorization':'token '+TK}}).then(r=>r.json())).tree.sha;
    const tree=[...del2].map(k=>({'path':'public/images/studio/'+k+'.webp','mode':'100644','type':'blob','sha':null}));
    const nt=(await fetch('https://api.github.com/repos/RoyWraps69/cfwforever/git/trees',{
      method:'POST',
      headers:{'Authorization':'token '+TK,'Content-Type':'application/json'},
      body:JSON.stringify({'base_tree':tsha,tree})
    }).then(r=>r.json())).sha;
    const nc=(await fetch('https://api.github.com/repos/RoyWraps69/cfwforever/git/commits',{
      method:'POST',
      headers:{'Authorization':'token '+TK,'Content-Type':'application/json'},
      body:JSON.stringify({'message':'delete: remove '+del2.size+' studio images','tree':nt,'parents':[csha]})
    }).then(r=>r.json())).sha;
    await fetch('https://api.github.com/repos/RoyWraps69/cfwforever/git/refs/heads/main',{
      method:'PATCH',
      headers:{'Authorization':'token '+TK,'Content-Type':'application/json'},
      body:JSON.stringify({'sha':nc})
    });
    toast('Deleted '+del2.size+' files!','#1a5c1a');
    del2.forEach(k=>{
      const i=D.findIndex(d=>d.k===k);
      if(i>-1) document.getElementById('cd'+i).style.display='none';
    });
    del2.clear(); upd();
  }catch(err){
    toast('Error: '+err.message,'#c33');
  }
  btn.textContent='Delete from GitHub'; btn.disabled=false;
}

function op(gi){
  const d=D[gi];
  fl=cur==='all'?D.slice():D.filter(x=>x.c===cur);
  mi=fl.findIndex(x=>x.k===d.k);
  sh();
}

function sh(){
  const d=fl[mi];
  document.getElementById('limg').src='/images/studio/'+d.k+'.webp';
  document.getElementById('linfo').textContent=d.k+'.webp  ('+(mi+1)+'/'+fl.length+')';
  document.getElementById('lcat').textContent=L[d.c]||d.c;
  const m=del2.has(d.k);
  const btn=document.getElementById('lbdel');
  btn.textContent=m?'Unmark':'Mark for deletion';
  btn.className='lbdel'+(m?' un':'');
  document.getElementById('lb').classList.add('open');
}

function cl(){ document.getElementById('lb').classList.remove('open'); }
function nv(dir){ mi=(mi+dir+fl.length)%fl.length; sh(); }

document.getElementById('lb').addEventListener('click',function(e){ if(e.target===this)cl(); });
document.addEventListener('keydown',e=>{
  if(!document.getElementById('lb').classList.contains('open'))return;
  if(e.key==='Escape')cl();
  if(e.key==='ArrowRight')nv(1);
  if(e.key==='ArrowLeft')nv(-1);
  if(e.key==='d'||e.key==='D')tgLb();
});

document.getElementById('tb').innerHTML=C.map(c=>
  '<button class="fb'+(c==='all'?' on':'')+'" data-c="'+c+'" onclick="sf(''+c+'')">'
  +(c==='all'?'All ('+D.length+')':(L[c]||c))+'</button>'
).join('');

sf('all');
