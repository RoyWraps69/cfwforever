<script>
(function(){
  var KEY='9977cc2a-1646-45b5-9bd3-e851c4db37da';
  var SUBS={'contact':'New Contact Form — Chicago Fleet Wraps','bay-rental':'New Bay Rental Request — Chicago Fleet Wraps','fleet-intake':'New Fleet Intake — Chicago Fleet Wraps','schedule-install':'New Install Request — Chicago Fleet Wraps','estimate-request':'New Estimate Request — Chicago Fleet Wraps'};
  function wire(){
    document.querySelectorAll('form[data-w3f]').forEach(function(f){
      if(f._w3f)return;f._w3f=1;
      f.addEventListener('submit',function(e){
        e.preventDefault();
        var btn=f.querySelector('.cfw-btn');
        if(btn){btn.disabled=true;btn.textContent='Sending...'}
        var d={};
        new FormData(f).forEach(function(v,k){d[k]=v});
        var fn=d['form-name']||'contact';
        d.access_key=KEY;
        d.subject=SUBS[fn]||'New Submission — Chicago Fleet Wraps';
        d.from_name='Chicago Fleet Wraps';
        d.replyto=d.email||'';
        fetch('https://api.web3forms.com/submit',{method:'POST',headers:{'Content-Type':'application/json','Accept':'application/json'},body:JSON.stringify(d)})
        .then(function(r){return r.json()})
        .then(function(r){
          if(r.success){f.innerHTML='<div style="padding:32px;text-align:center;border-top:3px solid #FFD700"><p style="font-family:Bebas Neue,sans-serif;font-size:36px;color:#FFD700;letter-spacing:3px;margin:0">✓ Received</p><p style="color:#E0E0E0;margin-top:8px">We'll be in touch within 2 hours.<br><a href="tel:+13125971286" style="color:#FFD700">(312) 597-1286</a></p></div>';}
          else{if(btn){btn.disabled=false;btn.textContent='Submit'}alert('Something went wrong. Call (312) 597-1286.');}
        })
        .catch(function(){if(btn){btn.disabled=false;btn.textContent='Submit'}alert('Something went wrong. Call (312) 597-1286.');});
      });
    });
  }
  document.readyState==='loading'?document.addEventListener('DOMContentLoaded',wire):wire();
})();
</script>
